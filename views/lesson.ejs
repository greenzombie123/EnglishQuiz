<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script>
      const lessonId = "<%= lessonId %>";
      const lessonName = "<%= lessonName %>";
    </script>
    <script src="./index.js" type="module" defer></script>
    <link rel="stylesheet" href="/lesson.css" />
  </head>

  <body>
    <header>Konnyaku English</header>
    <lesson-slider></lesson-slider>
    <template id="lesson-slider">
      <div class="lesson-slider"></div>
    </template>

    <template id="intro-slide">
      <style>
        :host {
          height: 100%;
          display: flex;
          flex-direction: column;

          /* Intro Slides */
          .words {
            flex: 3;
            display: flex;
            flex-direction: column;
            font-size: 1.7rem;

            .targetWord {
              display: flex;
              flex-direction: column;
              font-size: 6vw;
              justify-content: end;
            }

            .definition{
                font-size: 4vw;
            }

            div {
              flex: 1;
              display: flex;
              align-items: center;
              justify-content: center;
            }
          }

          .buttons {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 50px;

            button {
              font-size: 1.4rem;
              padding: 6px;
            }
          }
        }
      </style>
      <div class="words">
        <div class="targetWord"></div>
        <div class="definition"></div>
      </div>
      <div class="buttons">
        <button type="button" class="back">Back</button>
        <button type="button" class="next">Next</button>
      </div>
    </template>

    <template id="question-slide">
      <style>
        :host {
          height: 100%;
          display: flex;
          flex-direction: column;

          /* Intro Slides */
          .question {
            flex: 3;
            display: flex;
            flex-direction: column;
            font-size: 5vw;
            justify-content: center;
            align-items: center;
          }

          .buttons {
            flex: 1;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            align-items: center;
            gap: 50px;
            padding: 10px;

            button {
              font-size: 1.4rem;
              padding: 6px 10px;
            }
          }
        }

        @media screen and (width <=550px) {
          :host {

            .buttons{
                gap: 20px;
            }

             .buttons button {
              font-size: 0.9rem;
            }
          }
        }
      </style>
      <p class="question"></p>
      <div class="buttons">
        <button type="button"></button>
        <button type="button"></button>
        <button type="button"></button>
        <button type="button"></button>
      </div>
    </template>

    <template id="end-slide">
        <style>
        :host {
          form{
                height: 100%;
             display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

            p{
                font-size: 10vw;
            }

            button{
                font-size: 2vw;
                padding: 6px 10px;
            }
          }

         
        }
      </style>
      <form action="/lessons" method="get">
        <p>Good Job!</p>
        <button>Go Back To Lessons</button>
      </form>
    </template>
    <footer>Made By Green Zombie</footer>
  </body>
</html>
