<ul class="nogroup">
    <% nogroup.forEach(lesson => { %>
        <li> 
            <a class="lesson" href=<%= `/lessons/${lesson.id}?lessonname=${lesson.name}` %>><%= lesson.name %></a>
            <a class="icon">
                <img src="/edit.png" alt="">
            </a>
            <a class="icon" href="">
                <img src="/bin.png" alt="">
            </a>
        </li>
    <% }) %>
</ul>